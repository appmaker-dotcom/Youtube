# ============================================================
# YouTube Shorts Bot — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.
# ============================================================

# --- YouTube Data API ---
# Get this from: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- OAuth2 Credentials (for uploading to YouTube) ---
# Download from Google Cloud Console as client_secret.json
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# --- Target YouTube Channel ---
# The channel you want to monitor (URL or ID)
TARGET_CHANNEL_URL=https://www.youtube.com/@example

# --- Your YouTube Channel (for uploading Shorts) ---
UPLOAD_CHANNEL_ID=your_upload_channel_id_here

# --- OpenAI (Optional — for AI commentary) ---
# Leave blank to skip AI features
OPENAI_API_KEY=

# --- Bot Settings ---
# How often to check for new videos (in minutes)
CHECK_INTERVAL_MINUTES=30

# Max length of a Short in seconds (YouTube limit: 60)
MAX_SHORT_DURATION_SECONDS=59

# Min length of a clip to consider (seconds)
MIN_CLIP_DURATION_SECONDS=15

# --- Paths ---
MUSIC_FOLDER=./music/tracks
DOWNLOADS_FOLDER=./downloads
OUTPUT_FOLDER=./output